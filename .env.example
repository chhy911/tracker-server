# Docker Compose / 部署用环境变量（复制为 .env 后修改）
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=tracker_db
MYSQL_USER=tracker
MYSQL_PASSWORD=tracker_password

# Tracker 进程读取的数据库连接（docker-compose 已注入）
TRACKER_DB_HOST=localhost
TRACKER_DB_PORT=3306
TRACKER_DB_USER=tracker
TRACKER_DB_PASSWORD=tracker_password
TRACKER_DB_NAME=tracker_db
